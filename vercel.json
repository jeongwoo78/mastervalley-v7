{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/flux-transfer.js":      { "maxDuration": 60 },
    "api/check-prediction.js":   { "maxDuration": 60 },
    "api/replicate.js":          { "maxDuration": 60 },
    "api/generate-education.js": { "maxDuration": 60 },
    "api/master-feedback.js":    { "maxDuration": 60 },
    "api/deduct-credit.js":      { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
